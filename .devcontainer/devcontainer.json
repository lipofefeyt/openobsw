{
    "name": "openobsw",
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
    "features": {
        "ghcr.io/devcontainers/features/common-utils:2": {
            "installZsh": true,
            "configureZshAsDefaultShell": false,
            "installOhMyZsh": false,
            "upgradePackages": true
        },
        "ghcr.io/devcontainers/features/python:1": {
            "version": "3.12"
        },
        "ghcr.io/devcontainers/features/java:1": {
            "version": "21",
            "jdk": "ms"
        }
    },
    "mounts": [
        "source=${localWorkspaceFolder}/../opensvf,target=/workspace/opensvf,type=bind,consistency=cached",
        "source=${localWorkspaceFolder}/../opensvf-kde,target=/workspace/opensvf-kde,type=bind,consistency=cached"
    ],
    "runArgs": [
        "--privileged"
    ],
    "postCreateCommand": "bash .devcontainer/post-create.sh",
    "forwardPorts": [
        8090
    ],
    "remoteEnv": {
        "OPENOBSW_REPO": "${containerWorkspaceFolder}",
        "OPENSVF_REPO": "/workspace/opensvf",
        "OPENSVF_KDE_REPO": "/workspace/opensvf-kde"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cpptools",
                "ms-vscode.cmake-tools",
                "twxs.cmake",
                "ms-python.python",
                "ms-python.mypy-type-checker",
                "marus25.cortex-debug"
            ],
            "settings": {
                "cmake.configureOnOpen": false,
                "python.defaultInterpreterPath": "/usr/local/bin/python3"
            }
        }
    }
}